            },
            "openticketerlambdaspend4h": {
                "alarm_name": "open-ticketer_openticketerlambdaspend4h",
                "period": 14400,
                "statistic": "Sum",
                "alarm_actions": [
                    "${aws_sns_topic.emergency.arn}"
                ],
                "threshold": 13333306,
                "datapoints_to_alarm": 1,
                "insufficient_data_actions": [],
                "metric_name": "Duration",
                "evaluation_periods": 1,
                "alarm_description": "Open Ticketer Lambda Spend (4h)",
                "comparison_operator": "GreaterThanOrEqualToThreshold",
                "namespace": "AWS/Lambda",
                "dimensions": {
                    "FunctionName": "${aws_lambda_function.main.function_name}"
                }
            }
        },
        "aws_api_gateway_account": {
            "main": {
                "cloudwatch_role_arn": "${aws_iam_role.cloudwatch.arn}"
            }
        },
        "aws_iam_role": {
            "cloudwatch": {
                "name": "open-ticketer",
                "assume_role_policy": "{\"Version\":\"2012-10-17\",\"Statement\":[{\"Action\":\"sts:AssumeRole\",\"Effect\":\"Allow\",\"Principal\":{\"Service\":[\"apigateway.amazonaws.com\",\"lambda.amazonaws.com\"]},\"Sid\":\"\"}]}"
            }
        },
        "aws_sns_topic_subscription": {
            "emergency_primary": {
                "protocol": "email",
                "endpoint": "joseph@lightningkite.com",
                "topic_arn": "${aws_sns_topic.emergency.arn}"
            }
        },
        "aws_iam_role_policy": {
            "cloudwatch": {
                "role": "${aws_iam_role.cloudwatch.id}",
                "name": "open-ticketer_policy",
                "policy": "{\"Version\":\"2012-10-17\",\"Statement\":[{\"Action\":[\"logs:CreateLogGroup\",\"logs:CreateLogStream\",\"logs:DescribeLogGroups\",\"logs:DescribeLogStreams\",\"logs:PutLogEvents\",\"logs:GetLogEvents\",\"logs:FilterLogEvents\"],\"Resource\":\"*\",\"Effect\":\"Allow\"}]}"
            }
        }
    }
}