{
    "resource": {
        "aws_sns_topic": {
            "emergency": {
                "name": "open-ticketer_emergencies"
            }
        },
        "aws_cloudwatch_metric_alarm": {
            "openticketerlambdaspend1d": {
                "alarm_name": "open-ticketer_openticketerlambdaspend1d",
                "period": 86400,
                "statistic": "Sum",
                "alarm_actions": [
                    "${aws_sns_topic.emergency.arn}"
                ],
                "threshold": 39999920,
                "datapoints_to_alarm": 1,
                "insufficient_data_actions": [],
                "metric_name": "Duration",
                "evaluation_periods": 1,
                "alarm_description": "Open Ticketer Lambda Spend (1d)",
                "comparison_operator": "GreaterThanOrEqualToThreshold",
                "namespace": "AWS/Lambda",
                "dimensions": {
                    "FunctionName": "${aws_lambda_function.main.function_name}"
                }
            },
            "openticketerlambdaspend15m": {
                "alarm_name": "open-ticketer_openticketerlambdaspend15m",
                "period": 900,
                "statistic": "Sum",
                "alarm_actions": [
                    "${aws_sns_topic.emergency.arn}"
                ],
                "threshold": 3333326,
                "datapoints_to_alarm": 1,
                "insufficient_data_actions": [],
                "metric_name": "Duration",
                "evaluation_periods": 1,
                "alarm_description": "Open Ticketer Lambda Spend (15m)",
                "comparison_operator": "GreaterThanOrEqualToThreshold",
                "namespace": "AWS/Lambda",
                "dimensions": {
                    "FunctionName": "${aws_lambda_function.main.function_name}"
                }
            },
            "openticketerlambdaspend7d": {
                "alarm_name": "open-ticketer_openticketerlambdaspend7d",
                "period": 604800,
                "statistic": "Sum",
                "alarm_actions": [
                    "${aws_sns_topic.emergency.arn}"
                ],
                "threshold": 139999720,
                "datapoints_to_alarm": 1,
                "insufficient_data_actions": [],
                "metric_name": "Duration",
                "evaluation_periods": 1,
                "alarm_description": "Open Ticketer Lambda Spend (7d)",
                "comparison_operator": "GreaterThanOrEqualToThreshold",
                "namespace": "AWS/Lambda",
                "dimensions": {
                    "FunctionName": "${aws_lambda_function.main.function_name}"
                }
            },
            "openticketerlambdaspend5m": {
                "alarm_name": "open-ticketer_openticketerlambdaspend5m",
                "period": 300,
                "statistic": "Sum",
                "alarm_actions": [
                    "${aws_sns_topic.emergency.arn}"
                ],
                "threshold": 2222217,
                "datapoints_to_alarm": 1,
                "insufficient_data_actions": [],
                "metric_name": "Duration",
                "evaluation_periods": 1,
                "alarm_description": "Open Ticketer Lambda Spend (5m)",
                "comparison_operator": "GreaterThanOrEqualToThreshold",
                "namespace": "AWS/Lambda",
                "dimensions": {
                    "FunctionName": "${aws_lambda_function.main.function_name}"
                }
            },
            "openticketerlambdaspend1h": {
                "alarm_name": "open-ticketer_openticketerlambdaspend1h",
                "period": 3600,
                "statistic": "Sum",
                "alarm_actions": [
                    "${aws_sns_topic.emergency.arn}"
                ],
                "threshold": 6666653,
                "datapoints_to_alarm": 1,
                "insufficient_data_actions": [],
                "metric_name": "Duration",
                "evaluation_periods": 1,
                "alarm_description": "Open Ticketer Lambda Spend (1h)",
                "comparison_operator": "GreaterThanOrEqualToThreshold",
                "namespace": "AWS/Lambda",
                "dimensions": {
                    "FunctionName": "${aws_lambda_function.main.function_name}"
