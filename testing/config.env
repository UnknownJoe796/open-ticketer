# by Claude - Testing configuration for open-ticketer
# Part of lk-testing-scripts

# Ports (change to avoid conflicts with other projects)
BACKEND_PORT=8081
FRONTEND_PORT=8941

# Timeouts (seconds)
BACKEND_STARTUP_TIMEOUT=90
FRONTEND_STARTUP_TIMEOUT=120

# Settings file (using the project's existing settings.testing.json)
SETTINGS_FILE="${LK_TESTING_DIR}/settings.testing.json"

# Log files
BACKEND_LOG="${LK_TESTING_DIR}/.backend.log"
FRONTEND_LOG="${LK_TESTING_DIR}/.frontend.log"
ADMIN_TOKEN_FILE="${LK_TESTING_DIR}/.admin-token"
